{
  "rules": {
    "households": {
      "$householdId": {
        ".read": "auth != null",
        ".write": "auth != null && $householdId === ('hh_' + auth.uid) || root.child('householdMeta').child($householdId).child('members').child(auth.uid).exists()"
      }
    },
    "householdMeta": {
      "$householdId": {
        ".read": "auth != null",
        "members": {
          "$userId": {
            ".write": "auth != null && (auth.uid === $userId || $householdId === ('hh_' + auth.uid))"
          }
        },
        ".write": "auth != null && $householdId === ('hh_' + auth.uid)"
      }
    },
    "inviteCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
